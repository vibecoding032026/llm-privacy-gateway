# Dockerfile.client — Integration / load test runner
FROM python:3.12-slim

LABEL version="1.5.0"
LABEL description="Test runner for LLM Privacy Gateway"

WORKDIR /app

RUN pip install --no-cache-dir requests pytest httpx

COPY tests/ ./tests/

# Non-root user
RUN useradd -m -u 1001 testrunner
USER testrunner

ENV GATEWAY_URL=http://gateway:8000

# Run full integration test suite by default
CMD ["python", "-m", "pytest", "tests/test_full.py", "-v", "--tb=short"]
